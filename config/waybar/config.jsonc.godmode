{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 4,
  "height": 50,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": [
    "custom/omarchy",
    "hyprland/workspaces",
    "custom/active_window"
  ],
  
  "modules-center": [
    "custom/clock"
  ],
  
  "modules-right": [
    "group/media#media",
    "group/system#system",
    "group/hardware#hardware",
    "tray",
    "custom/gamemode",
    "custom/update",
    "custom/notification-silencing-indicator"
  ],

  // --- GROUPS ---

  "group/system#system": {
    "orientation": "inherit",
    "modules": [
      "cpu",
      "custom/temp",
      "memory"
    ]
  },

  "group/media#media": {
    "orientation": "inherit",
    "modules": [
      "custom/weather",
      "custom/media"
    ]
  },

  "group/hardware#hardware": {
    "orientation": "inherit",
    "modules": [
      "network",
      "bluetooth",
      "pulseaudio",
      "battery"
    ]
  },

  // --- MODULES ---

  "custom/omarchy": {
    "format": "≤░μΘ",
    "on-click": "omarchy-menu",
    "on-click-right": "xdg-terminal-exec",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{id} {windows}",
    "window-rewrite-default": "≤▒Υ╖",
    "window-rewrite": {
      // --- Browsers & Webapps ---
      "google-chrome": "≤░Λψ",
      "chromium": "≤░Λψ",
      "firefox": "≤░Ι╣",
      "brave-browser": "≤░Δψ",
      "microsoft-edge": "≤░Θσ",
      "vivaldi-stable": "≤░Ψθ",
      "tor-browser": "ΎΞ▒",
      "zen": "≤░Ι╣",
      "chrome-web.whatsapp.com__-Default": "≤░Ψμ",
      "chrome-youtube.com__-Default": "≤░ΩΔ",
      "chrome-chatgpt.com__-Default": "≤░γσ",
      "chrome-claude.ai__-Default": "≤░γσ",
      "chrome-deepseek.com__-Default": "≤░γσ",
      "chrome-gemini.google.com__-Default": "≤░γσ",
      "chrome-grok.com__-Default": "≤▒γμ",
      "chrome-facebook.com__-Default": "≤░Ιχ",
      "chrome-www.instagram.com__-Default": "≤░ΕΕ",
      "chrome-x.com__-Default": "≤░Ωγ",
      "chrome-www.reddit.com__-Default": "≤░ΣΞ",
      "chrome-github.com__-Default": "≤░Λν",
      "chrome-mail.google.com__-Default": "≤░Λτ",
      "chrome-drive.google.com__-Default": "≤░κ╡",
      "chrome-messages.google.com__-Default": "≤░φ╣",
      "chrome-photos.google.com__-Default": "≤░ΕΕ",
      "chrome-www.google.com_maps__-Default": "≤░Ωγ",
      "chrome-contacts.google.com__-Default": "≤░θ╢",
      "chrome-www.netflix.com__-Default": "≤░ζΗ",
      "chrome-canva.com__-Default": "≤░Χ╝",
      "chrome-www.pinterest.com__-Default": "≤░ΡΖ",
      "chrome-colab.research.google.com__-Default": "≤▒Ηθ",
      "chrome-campusvirtual.unam.mx__-Default": "≤▒βζ",
      "chrome-estudiante.unam.mx__-Default": "≤▒βζ",

      // --- Development & Editors ---
      "code": "≤░ρη",
      "code-url-handler": "≤░ρη",
      "jetbrains-studio": "≤░│γ",
      "android-studio": "≤░│γ",
      "sublime_text": "Όης",
      "jetbrains-idea": "Όη╡",
      "jetbrains-pycharm": "≤▒Ηθ",
      "jetbrains-webstorm": "≤▒ΗΔ",
      "neovide": "ΎΞψ",
      "nvim": "ΎΞψ",
      "emacs": "Όα▓",
      "vim": "ΌθΖ",
      "texstudio": "≤▒Υ╖",
      "obsidian": "≤▒Υπ",
      "typora": "≤░Πτ",
      "org.kde.kate": "≤░στ",
      "org.kde.kwrite": "≤░στ",
      "cmake-gui": "≤▒Ιγ",
      "assistant": "≤░ηΜ",
      "designer": "≤░β╡",
      
      // --- Terminals ---
      "kitty": "ΌηΧ",
      "Alacritty": "ΌηΧ",
      "com.mitchellh.ghostty": "ΌηΧ",
      "foot": "≤░η╖",
      "TUI.tile": "ΌηΧ",
      "visidata": "≤▒Ψτ",
      "btop": "≤░Ες",
      
      // --- Communication & Social ---
      "discord": "≤░βψ",
      "vesktop": "≤░βψ",
      "discord-ptb": "≤░βψ",
      "WhatsApp": "≤░Ψμ",
      "signal": "≤░ΙΟ",
      "telegram-desktop": "ΎΜΗ",
      "com.ayugram.desktop": "ΎΜΗ",
      "slack": "≤░Τ▒",
      "zoom": "≤░Χπ",
      "teams-for-linux": "≤░Λ╗",
      "localsend": "≤▒γ╛",
      
      // --- Media & Design ---
      "spotify": "≤░ΥΘ",
      "cider": "≤░ΥΘ",
      "vibez": "≤░ΥΘ",
      "Vibez": "≤░ΥΘ",
      "spotiflac": "≤░ΥΘ",
      "cliamp": "≤░ΟΗ",
      "vlc": "≤░Χ╝",
      "mpv": "≤░Χ╝",
      "com.stremio.stremio": "≤░ζΗ",
      "audacity": "≤░ΟΗ",
      "org.kde.kdenlive": "≤░Χβ",
      "org.shotcut.Shotcut": "≤░Χβ",
      "com.obsproject.Studio": "≤░ΡΝ",
      "blender": "≤░Γτ",
      "gimp": "ΎΝ╕",
      "Inkscape": "ΎΝ╗",
      "org.kde.krita": "ΎΝ╜",
      "imv": "≤░ΕΕ",
      
      // --- Productivity & Documents ---
      "org.gnome.Nautilus": "≤░ζ░",
      "Thunar": "≤░ζ░",
      "org.kde.dolphin": "≤░ζ░",
      "org.kde.okular": "≤░Ιο",
      "net.code-industry.masterpdfeditor5": "≤░Ιο",
      "com.github.jeromerobert.pdfarranger": "≤░Ιο",
      "onlyoffice-desktopeditors": "≤░Ιβ",
      "libreoffice-writer": "≤░Ιβ",
      "libreoffice-calc": "≤░Ιδ",
      "libreoffice-impress": "≤░Ιπ",
      
      // --- Gaming ---
      "steam": "≤░ΥΥ",
      "lutris": "≤░║╡",
      "heroic": "≤░║╡",
      "net.lutris.Lutris": "≤░║╡",
      "net.davidotek.pupgui2": "≤░║╡",
      "Minecraft": "≤░Ξ│",
      "The Sims 4": "≤░Ξ│",
      "The Forest": "≤░Ξ│",
      "Left 4 Dead 2": "≤░Ξ│",
      "unityhub": "≤░γψ",
      "Unity": "≤░γψ",
      "sims4modmanager": "≤░γψ",
      
      // --- System & Utilities ---
      "org.gnome.Calculator": "≤░ςγ",
      "gpartedbin": "≤░╖Φ",
      "org.gnome.DiskUtility": "≤░╖Φ",
      "com.github.wwmm.easyeffects": "≤░ΥΔ",
      "scrcpy": "≤░Ψθ",
      "droidcam": "≤░ΕΕ",
      "webcamoid": "≤░ΕΕ",
      "org.kde.kdeconnect.app": "≤░Εκ",
      "bitwarden": "≤░ηΑ",
      "keepassxc": "≤░ηΑ",
      "dropbox": "≤░Θς",
      "timeshift-gtk": "≤░Βψ"
    },

    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    }
  },

  "custom/active_window": {
    "exec": "~/.config/waybar/window.sh",
    "return-type": "json",
    "markup": true,
    "max-length": 30
  },

  "custom/clock": {
    "exec": "~/.config/waybar/clock.sh",
    "interval": 1,
    "return-type": "json",
    "tooltip": false
  },

  "cpu": {
    "interval": 2,
    "format": "ΎΤ╝ {usage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },

  "custom/temp": {
    "exec": "cat /sys/class/hwmon/hwmon4/temp1_input | awk '{print \"ΎΜΚ \" int($1/1000) \"┬░C\"}'",
    "interval": 5,
    "tooltip": false
  },

  "memory": {
    "interval": 2,
    "format": "Ό┐Ζ {percentage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },

  "custom/weather": {
    "exec": "/home/elyefris/.local/share/omarchy/default/waybar/weather.sh",
    "return-type": "json",
    "interval": 1800,
    "format": "{}"
  },

  "custom/media": {
    "exec": "title=$(playerctl metadata title 2>/dev/null); if [ -n \"$title\" ]; then echo \"ΎΑΒ ${title:0:20}...\"; else echo \"ΎΑΒ No Media\"; fi",
    "interval": 2,
    "on-click": "playerctl play-pause"
  },

  "network": {
    "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
    "format-wifi": "{icon}",
    "format-ethernet": "≤░Να",
    "format-disconnected": "≤░νχ",
    "on-click": "omarchy-launch-wifi"
  },

  "bluetooth": {
    "format": "≤░Γψ",
    "format-disabled": "≤░Γ▓",
    "format-connected": "ΎΛΥ",
    "on-click": "omarchy-launch-bluetooth"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "Ό╗ρ",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "omarchy-launch-or-focus-tui wiremix"
  },

  "battery": {
    "interval": 2,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤▒ΡΜ {capacity}% ({power}W)",
    "format-plugged": "ΎΘο {capacity}%",
    "format-alt": "{icon} {time} ({power}W)",
    "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    "on-click": "omarchy-menu power",
    "tooltip-format": "Power: {power}W\nTime: {time}"
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },

  "custom/update": {
    "format": "ΎΑκ",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "interval": 21600
  },

  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "return-type": "json"
  },

  "custom/gamemode": {
    "exec": "test -f ~/.cache/hypr_gamemode && echo '{\"text\":\"ΎΕδ\", \"class\":\"active\"}' || echo '{\"text\":\"ΎΕδ\", \"class\":\"inactive\"}'",
    "on-click": "test -f ~/.cache/hypr_gamemode && (rm ~/.cache/hypr_gamemode && hyprctl keyword animations:enabled 1 && hyprctl keyword decoration:blur:enabled 1) || (touch ~/.cache/hypr_gamemode && hyprctl keyword animations:enabled 0 && hyprctl keyword decoration:blur:enabled 0)",
    "interval": 1,
    "return-type": "json",
    "tooltip": true,
    "tooltip-format": "GameMode (Toggles animations/blur)"
  }
}
